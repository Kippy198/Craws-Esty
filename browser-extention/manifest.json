{
    "manifest_version": 3,
    "name": "Craw Data Project",
    "version": "1.0.0",
    "description": "Du an de lay du lieu tu trong web",
    "permissions":
    [
        "activeTab",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://etsy.toidispy.com/*",
        "http://localhost:3000/*",
        "https://fthzm2m3h3.execute-api.ap-southeast-1.amazonaws.com/*"
    ],
    "background": {
        "service_worker" : "background/background.js",
        "type":"module"
    },
    "content_scripts": [
        {
            "matches": ["https://etsy.toidispy.com/*"],
            "js": ["content/content.js"]
        }
    ],
    "action" : {
        "default_title": "Craw Data Project",
        "default_popup": "popup/popup.html"
    }
}